# Myxxit Environment Configuration
# Copy this file to .env.local and fill in your values for local development

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_project_id_here"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key_here"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Feature Flags
# ============

# Promoter Route Development Bypass
# Allows unauthenticated access to promoter routes for local development
# 
# Context: Developers need to test promoter features and workflows without
# authentication context. This flag provides a safe way to bypass auth checks
# in development while maintaining strict security in production.
#
# Values:
#   - false  (default, production-safe) - Routes require 'promoter' user authentication
#   - true   (dev-only) - Routes accessible without authentication
#
# Important:
#   - This CANNOT be enabled in production (automatically blocked)
#   - Only use in .env.local for local development
#   - Always keep as 'false' in version control
#   - Never commit a .env.local with this set to 'true'
#
# To use in local development:
#   1. Create .env.local file
#   2. Add: VITE_ALLOW_ROUTE_BYPASS=true
#   3. Restart the dev server
#   4. Test promoter routes without authentication
#
VITE_ALLOW_ROUTE_BYPASS=false
